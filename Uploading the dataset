# KNN
from sklearn.neighbors import KNeighborsClassifier
def train_knn(X_train, y_train):

    meter = pyRAPL.Measurement("KNN")
    meter.begin()
    start_time = time.time()
    model = KNeighborsClassifier(n_neighbors=5)
    model.fit(X_train, y_train)
    training_time = time.time() - start_time
    meter.end()
    energy_joules = sum(meter.result.pkg) / 1_000_000
    return (model, training_time, energy_joules)

# results
def save_results(dataset_name, model_name, accuracy, training_time, energy):

    results.append({"Dataset": dataset_name, "Model": model_name,"Accuracy": accuracy,
                    "Training_Time": training_time, "Energy_Joules": energy })

# Run the model multiple times
def run_multiple_times(train_function, X_train, y_train, X_test, y_test, runs=5,**params):
    # Store the results from each run
    all_results = []
    accuracies = []
    training_times = []
    energies = []
    
    for i in range(runs):
        print("\nRun:", i+1)
        # Train the model
        model, training_time, energy = train_function(X_train,y_train, **params)       
        # Evaluate the trained model
        accuracy = evaluate_model(model,X_test, y_test)
        # Store every run
        all_results.append({"Run": i+1, "Accuracy": accuracy, "Training_Time": training_time, "Energy_Joules": energy})
        # Save the results
        accuracies.append(accuracy)
        training_times.append(training_time)
        energies.append(energy)
    
    results_table = pd.DataFrame(all_results)
    print("\nAll Runs:")
    print(results_table)
    
    median_results = {"Accuracy": np.median(accuracies), "Training_Time": np.median(training_times), "Energy_Joules": np.median(energies)}
    
    print("\nMedian Results:")
    print(median_results)
    return results_table, median_results

