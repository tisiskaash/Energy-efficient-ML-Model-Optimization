# Imports
import os
import pandas as pd
from scipy.io import arff

# Function to load either a CSV or ARFF dataset
def load_dataset(filepath):
    """Load a CSV or ARFF file into a pandas DataFrame."""

    # Get the file extension (.csv or .arff)
    extension = os.path.splitext(filepath)[1].lower()

    # Load CSV file
    if extension == ".csv":
        return pd.read_csv(filepath)

    # Load ARFF file
    if extension == ".arff":
        data, _ = arff.loadarff(filepath)
        df = pd.DataFrame(data)

    # Show an error if the file type is not supported
    raise ValueError("Only CSV and ARFF files are supported.")



